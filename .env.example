# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TWILIO_ACCOUNT_SID: Your Twilio Account SID for sending booking SMS.
TWILIO_ACCOUNT_SID=

# TWILIO_AUTH_TOKEN: Your Twilio Auth Token.
TWILIO_AUTH_TOKEN=

# TWILIO_FROM_NUMBER: Your purchased Twilio phone number sending notifications.
TWILIO_FROM_NUMBER=

# TWILIO_TO_ADMIN_NUMBER: The physical phone number of SGF Narela store/admin to receive alerts.
TWILIO_TO_ADMIN_NUMBER=

# SUPABASE_URL: Your Supabase Project API URL
SUPABASE_URL=

# SUPABASE_ANON_KEY: Your Supabase Project Anonymous API Key
SUPABASE_ANON_KEY=

# STRIPE_SECRET_KEY: Stripe Secret Key for payment integration (server-side only)
STRIPE_SECRET_KEY=

# VITE_STRIPE_PUBLISHABLE_KEY: Stripe Publishable Key for the React frontend
VITE_STRIPE_PUBLISHABLE_KEY=

